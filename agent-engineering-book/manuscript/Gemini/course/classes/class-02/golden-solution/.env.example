# Copy this file to .env and fill in real values locally. Never commit .env.
# .env is expected to be listed in .gitignore.

# Google Cloud project used for Gemini / ADK calls (added starting Class 4).
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Gemini model identifier, centralized here so it is never hardcoded
# in application code (see Class 3 / Book 1 §3.1).
WIDGETWARE_MODEL_ID=gemini-2.5-flash
